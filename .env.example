# Frontend (Vite) variables
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_signed_upload_preset

# Optional: Cloudinary named transformation used in AI preview (without "t_" prefix)
VITE_CLOUDINARY_AI_TEMPLATE=portrait_ai

# Optional: enable debug mode (uses test background image, shows uploader debug panel)
VITE_SHOW_UPLOADER_DEBUG=false

# Supabase publishable key — safe for the browser, works with RLS policies
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Netlify Function server-side variables (do NOT use VITE_ prefix)
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
SUPABASE_URL=your_supabase_project_url
SUPABASE_SECRET_KEY=your_supabase_secret_key
SITE_URL=https://your-site.example

# Przelewy24 API integration
P24_MERCHANT_ID=your_przelewy24_merchant_id
P24_POS_ID=your_przelewy24_pos_id
P24_CRC=your_przelewy24_crc
P24_API_KEY=your_przelewy24_api_key
P24_API_BASE_URL=https://sandbox.przelewy24.pl/api/v1

# Optional override for the Przelewy24 webhook target
P24_STATUS_URL=https://your-site.example/.netlify/functions/przelewy24-webhook

# Debug-only endpoint (disabled by default)
DEBUG_ORDERS_ENABLED=false
DEBUG_ORDERS_TOKEN=your_debug_orders_token

# Admin-only shipment update endpoint token
ADMIN_SHIPMENT_TOKEN=your_admin_shipment_token

# HubSpot CRM integration (project-based app static token)
HS_PRIVATE_APP_ACCESS_TOKEN=your_hubspot_private_app_access_token
HUBSPOT_API_BASE_URL=https://api.hubapi.com
